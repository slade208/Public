## This is the list of cheats that are accessible via curl operations.dev/<name>

operations.dev/awscli                         - Awscli commands related to S3/Hyperstore
operations.dev/config                         - Commands to look at configuration stuff
operations.dev/custom                         - Commands for customization
operations.dev/git                            - github command line notes
operations.dev/hsctl                          - Hyperstore common hsctl commands
operations.dev/hsh                            - HSH 
operations.dev/license                        - Cloudian license stuff
operations.dev/logs                           - Log descriptions
operations.dev/osmigrate                      - Cloudian Cent to Rocky migration
operations.dev/repair                         - Repair notes
operations.dev/upgrade                        - Hyperstore upgrade tips
operations.dev/vmware                         - vmware stuff

Get-CimInstance Win32_Process -Filter "Name='explorer.exe'" | ForEach-Object { [PSCustomObject]@{ PID=$_.ProcessId; WS_KB=[math]::Round($_.WorkingSetSize/1KB); ParentPID=$_.ParentProcessId; ParentName=(Get-CimInstance Win32_Process -Filter "ProcessId=$($_.ParentProcessId)" -ErrorAction SilentlyContinue).Name } }

Get-ItemProperty "HKLM:\SOFTWARE\Microsoft\Windows\CurrentVersion\Explorer\ShellExecuteHooks" -ErrorAction SilentlyContinue

Get-ChildItem "HKLM:\SOFTWARE\Microsoft\Windows\CurrentVersion\Explorer\Browser Helper Objects" -ErrorAction SilentlyContinue
